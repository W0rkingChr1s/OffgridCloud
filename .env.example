# OffgridCloud configuration. Copy to .env and adjust.
# All variables are prefixed with OGC_.

# --- Security (CHANGE THESE!) ------------------------------------------------
# The installers (deploy/install.sh, quickstart.sh, install.ps1) generate the
# key and admin password automatically. Only set them by hand for a manual or
# Docker setup.  Key:  python3 -c "import secrets; print(secrets.token_urlsafe(48))"
OGC_SECRET_KEY=please-generate-a-long-random-value
OGC_INITIAL_ADMIN_EMAIL=admin@offgrid.local
OGC_INITIAL_ADMIN_PASSWORD=please-set-a-strong-password

# --- General -----------------------------------------------------------------
OGC_ENVIRONMENT=production

# --- Storage -----------------------------------------------------------------
# App state / SQLite database.
OGC_DATA_DIR=./data
# Media buffer. On a Raspberry Pi, point this at an external USB SSD
# (NOT the microSD card) — e.g. /mnt/ssd/offgrid-buffer
OGC_BUFFER_DIR=./data/buffer

# --- Transfer engine ---------------------------------------------------------
OGC_RCLONE_BINARY=rclone

# --- Bandwidth measurement (optional) ----------------------------------------
# Default target for the active bandwidth probe. "Measure now" works out of the
# box with this; only change it to use your own test file.
# OGC_DEFAULT_PROBE_URL=https://speed.cloudflare.com/__down?bytes=10000000

# --- Updates -----------------------------------------------------------------
# Repo checked for new releases (System page shows current vs. latest).
# OGC_GITHUB_REPO=W0rkingChr1s/OffgridCloud
# One-click self-update from the web UI is ON by default; `install.sh` always
# adds the NOPASSWD sudoers rule so `sudo update.sh` runs headless. To turn the
# button OFF (e.g. Docker, where you replace the image), set either of:
# OGC_SELF_UPDATE=false
# OGC_UPDATE_COMMAND=
# Override the command only if your install prefix differs from /opt/offgridcloud:
# OGC_UPDATE_COMMAND=sudo /opt/offgridcloud/src/deploy/update.sh

# --- System power control ----------------------------------------------------
# "System steuern" buttons in the web UI (restart the service, reboot or shut
# down the box) are ON by default; `install.sh` always adds the NOPASSWD sudoers
# rules. Clear a command to disable just that action (button greyed out):
# OGC_RESTART_SERVICE_COMMAND=sudo /usr/bin/systemctl restart offgridcloud
# OGC_REBOOT_COMMAND=sudo /usr/bin/systemctl reboot
# OGC_SHUTDOWN_COMMAND=sudo /usr/bin/systemctl poweroff

# --- Network redundancy / AP fallback (optional) -----------------------------
# The box can host its own Wi-Fi access point when it loses its uplink, so the
# field team can still upload locally. Set up by `install.sh --with-ap-fallback`
# (or deploy/netfallback/install.sh). Manage it in the web UI under "Netzwerk".
# Where the desired config is exported for the privileged helper + watchdog.
# Unset -> <OGC_DATA_DIR>/network.json (written 0600, contains Wi-Fi passphrases).
# OGC_NET_CONFIG_FILE=/opt/offgridcloud/data/network.json
# Privileged command that applies the exported config to NetworkManager. Wired
# up automatically by the installer via a NOPASSWD sudoers rule; leave off otherwise.
# OGC_NET_APPLY_COMMAND=sudo /opt/offgridcloud/deploy/netfallback/apply.sh /opt/offgridcloud/data/network.json
