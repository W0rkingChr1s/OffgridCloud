# OffgridCloud configuration. Copy to .env and adjust.
# All variables are prefixed with OGC_.

# --- Security (CHANGE THESE!) ------------------------------------------------
# The installers (deploy/install.sh, quickstart.sh, install.ps1) generate the
# key and admin password automatically. Only set them by hand for a manual or
# Docker setup.  Key:  python3 -c "import secrets; print(secrets.token_urlsafe(48))"
OGC_SECRET_KEY=please-generate-a-long-random-value
OGC_INITIAL_ADMIN_EMAIL=admin@offgrid.local
OGC_INITIAL_ADMIN_PASSWORD=please-set-a-strong-password

# --- General -----------------------------------------------------------------
OGC_ENVIRONMENT=production

# --- Storage -----------------------------------------------------------------
# App state / SQLite database.
OGC_DATA_DIR=./data
# Media buffer. On a Raspberry Pi, point this at an external USB SSD
# (NOT the microSD card) — e.g. /mnt/ssd/offgrid-buffer
OGC_BUFFER_DIR=./data/buffer

# --- Transfer engine ---------------------------------------------------------
OGC_RCLONE_BINARY=rclone

# --- Bandwidth measurement (optional) ----------------------------------------
# Default target for the active bandwidth probe. "Measure now" works out of the
# box with this; only change it to use your own test file.
# OGC_DEFAULT_PROBE_URL=https://speed.cloudflare.com/__down?bytes=10000000

# --- Updates (optional) ------------------------------------------------------
# Repo checked for new releases (System page shows current vs. latest).
# OGC_GITHUB_REPO=W0rkingChr1s/OffgridCloud
# One-click self-update from the web UI. Set up automatically by
# `install.sh --self-update`; leave off otherwise.
# OGC_SELF_UPDATE=false
# OGC_UPDATE_COMMAND=sudo /opt/offgridcloud/src/deploy/update.sh
