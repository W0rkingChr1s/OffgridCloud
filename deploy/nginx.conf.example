# OffgridCloud reverse proxy (nginx). Adjust server_name and certificate paths.
# Generate a self-signed cert for field use:
#   sudo openssl req -x509 -nodes -days 825 -newkey rsa:2048 \
#     -keyout /etc/ssl/private/offgrid.key -out /etc/ssl/certs/offgrid.crt \
#     -subj "/CN=offgrid.local"

server {
    listen 443 ssl;
    server_name offgrid.local;

    ssl_certificate     /etc/ssl/certs/offgrid.crt;
    ssl_certificate_key /etc/ssl/private/offgrid.key;

    # Large media uploads.
    client_max_body_size 0;

    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Server-Sent Events stream: disable buffering, keep the connection open.
    location /api/events {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 3600s;
    }
}

server {
    listen 80;
    server_name offgrid.local;
    return 301 https://$host$request_uri;
}
