# OffgridCloud reverse proxy with automatic HTTPS (Caddy).
#
#   sudo caddy run --config deploy/Caddyfile
#
# Replace the domain. Caddy obtains/renews a real certificate automatically.
offgrid.example.com {
    reverse_proxy localhost:8000
    # SSE (/api/events) works out of the box — Caddy does not buffer responses.
}

# --- Offline / field use (no public domain) -------------------------------
# Use a self-signed certificate Caddy manages locally. Replace the address with
# the Pi's hostname or IP and uncomment.
#
# https://offgrid.local {
#     tls internal
#     reverse_proxy localhost:8000
# }
